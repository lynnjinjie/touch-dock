{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TouchDock",
  "version": "0.2.9",
  "identifier": "com.touchdock.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "TouchDock",
        "width": 940,
        "height": 680,
        "minWidth": 680,
        "minHeight": 540,
        "resizable": true,
        "fullscreen": false
      },
      {
        "label": "tray-panel",
        "title": "TouchDock",
        "url": "index.html?surface=tray",
        "width": 280,
        "height": 428,
        "resizable": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self'; script-src 'self'; img-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "macOS": {
      "signingIdentity": "-"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
