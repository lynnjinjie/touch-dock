{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Minimum permissions for the TouchDock main window.",
  "windows": ["main", "tray-panel"],
  "permissions": [
    "core:default",
    {
      "identifier": "opener:allow-open-url",
      "allow": [
        { "url": "https://github.com/lynnjinjie/touch-dock/releases/**" }
      ]
    }
  ]
}
